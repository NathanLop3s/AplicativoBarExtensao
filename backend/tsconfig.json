{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext", 
    "esModuleInterop": true,        
    "skipLibCheck": true,
    "strict": true,
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx", 
    
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  }
}